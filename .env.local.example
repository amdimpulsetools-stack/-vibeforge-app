# MP_WEBHOOK_URL=https://tu-dominio.com/api/mercadopago/webhook

# ===========================================
# SMTP (Email)
# Para Gmail: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=tu@gmail.com  SMTP_PASS=contraseña de app
# Para Outlook: SMTP_HOST=smtp.office365.com  SMTP_PORT=587
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=noreply@tuclinica.com  (opcional, si quieres un remitente distinto)

